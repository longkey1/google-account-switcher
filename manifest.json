{
  "manifest_version": 3,
  "name": "Google Account Switcher",
  "version": "0.0.4",
  "description": "Automatically switch Google accounts based on the service domain.",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "storage"
  ],
  "host_permissions": [
    "*://*.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html"
}
